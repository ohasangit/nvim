{
  "http.proxy": "http://proxy-lmi.global.lmco.com:80/",
  "http.proxyStrictSSL": false,

  "languageserver": {
    "dockerfile": {
      "command": "docker-langserver",
      "filetypes": ["dockerfile"],
      "args": ["--stdio"]
